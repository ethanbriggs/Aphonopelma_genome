#map the recovered single copy BUSCOs back to the genomes

#!/bin/bash
#SBATCH -J minimap2
#SBATCH -C "ceph"
#SBATCH --mail-type=BEGIN,END,FAIL
#SBATCH --mail-user=ebriggs@uidaho.edu
#SBATCH -p eight
#SBATCH --mem=200G
#SBATCH --cpus-per-task=24

#load minimap2
. /usr/modules/init/bash
module load minimap2
module load samtools
module load bedtools

minimap2 -d Ste_ten.mmi /mnt/zeta/ebriggs/spider_synteny/genomes/Steten.fna
minimap2 -a Ste_ten.mmi  /mnt/ceph/hamiltonlab_data/EJB_WGS/Thera_ref_genome/BUSCO/fastas/GCA_044658465.1_ASM4465846v1_genomic_BUSCO/run_arachnida_odb10/busco_sequences/single_copy_busco_sequences/*.fna > Steten_BUSCOS.sam 

samtools view -S -b Steten_BUSCOS.sam  > Steten_BUSCOS.bam
bedtools bamtobed -i Steten_BUSCOS.bam > Steten_BUSCOS.bed

#convert the bed file into the correct chrom format for odp
awk '{print $4, $1, $6, $2, $3}' Steten_BUSCOS.bed > Steten.chrom

cat Steten.chrom \
  | tr -d '\r' \
  | sed 's/[[:space:]]\+/\t/g' \
  | awk -F'\t' 'NF==5' > StetenClean.chrom


#END of script



