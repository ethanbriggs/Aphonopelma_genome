library(ggplot2)


# read in data

df_fig2 <- read.csv("Gsize_cov_comp.csv")


ggplot(df_fig2, aes(x = Coverage, y = Complete, color = rank)) +
  geom_point(size = 5) +
  labs(x = "Coverage", y = "BUSCOs Complete (%)", title = "Genome Completeness vs Coverage") +
  theme_light() +
  theme(
    plot.title = element_text(hjust = 0.5),
    legend.title = element_blank()
  ) + 
  scale_x_continuous(breaks = seq(0, 200, by = 25)) +
  scale_y_continuous(breaks = seq(95, 100, by = 0.5))+
  scale_color_manual(values = c(
    "Mygalomorphae" = "#41B6E6FF",
    "Mesothelae" = "#DB3EB1FF",
