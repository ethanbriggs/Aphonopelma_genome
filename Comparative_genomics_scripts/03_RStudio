    "Araneomorphae:Eresidae" = "#FEDD00FF",
    "Araneomorphae:Uloboridae" = "#86DD45FF",
    "Araneomorphae:RTA" = "brown",
    "Araneomorphae:Araneoidea"      = "#000000FF"))


