






#!/bin/bash
#SBATCH -J minimap2
#SBATCH -C "ceph"
#SBATCH --mail-type=BEGIN,END,FAIL
#SBATCH --mail-user=ebriggs@uidaho.edu
#SBATCH -p gpu-8
#SBATCH --mem=500G
#SBATCH --cpus-per-task=40

#load minimap2
. /usr/modules/init/bash
module load minimap2
module load samtools

HiC_reads=/mnt/ceph/hamiltonlab_data/EJB_WGS/Thera_ref_genome/HiC_scaffolding/HiC_reads/

#index ref to get mmi for minimap2
minimap2 -d APH_5344_yahs_2R.mmi yahs_2rounds_.out_scaffolds_final.fa

# Align to assembly/ref alignment
minimap2 -ax sr APH_5344_yahs_2R.mmi ${HiC_reads}HiC_R1_concat.fastq.gz ${HiC_reads}HiC_R2_concat.fastq.gz > APH_5344_HiC.sam

samtools view -S -b APH_5344_HiC.sam > APH_5344_HiC_aligned.bam

samtools sort -o APH_5344_yahs_2R_HiC_aligned_sorted.bam APH_5344_HiC_aligned.bam


#####Pretext

conda activate pretext
module load samtools

samtools view -h APH_5344_yahs_2R_HiC_aligned_sorted.bam | PretextMap -o APH_5344_yahs_2R.pretext

PretextSnapshot -m APH_5344_yahs_2R.pretext  --sequences "=full" -f png

scp ebriggs@fortyfive.hpc.uidaho.edu:/mnt/ceph/hamiltonlab_data/EJB_WGS/Thera_ref_genome/HiC_scaffolding/test_concat_pairs/2rounds/minimap2/APH_5344_yahs_2R_snapshots/APH_5344_yahs_2R_FullMap.png ./

